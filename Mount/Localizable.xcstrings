{
  "sourceLanguage" : "en",
  "strings" : {
    "enableFileSystemExtension.cancel" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbrechen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancel"
          }
        }
      }
    },
    "enableFileSystemExtension.gettingStarted" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Getting Started Guide öffnen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Getting Started Guide"
          }
        }
      }
    },
    "enableFileSystemExtension.header" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dateisystemerweiterung aktivieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable File System Extension"
          }
        }
      }
    },
    "enableFileSystemExtension.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere die %1$(productName)@ Dateisystemerweiterung.\n\nÖffne Systemeinstellungen › Allgemein › Anmeldeobjekte & Erweiterungen. Klicke unter Erweiterungen auf Nach Kategorie. Klicke neben Dateisystemerweiterungen auf das Info-Symbol und aktiviere die %1$(productName)@ Dateisystemerweiterung.\n\nVersuche anschließend erneut, das Volume einzubinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable the %1$(productName)@ file system extension.\n\nOpen System Settings › General › Login Items & Extensions. Under Extensions, click By Category. Click the info symbol next to File System Extensions and enable the %1$(productName)@ file system extension.\n\nThen try mounting the volume again."
          }
        }
      }
    },
    "enableFileSystemExtension.systemSettings" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Systemeinstellungen öffnen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings"
          }
        }
      }
    },
    "installHelperTools.cancel" : {
      "extractionState" : "manual",
