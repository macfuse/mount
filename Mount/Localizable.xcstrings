        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilfsprogramm installieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Install Helper Tool"
          }
        }
      }
    },
    "installHelperTools.install" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilfsprogramm installieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Install Helper Tool"
          }
        }
      }
    },
    "installHelperTools.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Installiere das Hilfsprogramm, das zum Einbinden von %1$(productName)@ Volumes erforderlich ist. Gib dazu den Namen und das Passwort eines Administrators ein.\n\nDas Volume wird anschließend automatisch eingebunden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Install the helper tool required to mount %1$(productName)@ volumes. Enter an administrator name and password to continue.\n\nAfter the helper tool is installed, the volume is mounted automatically."
          }
        }
      }
    },
