    "registerFileSystemExtension.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registriere die %1$(productName)@ Dateisystemerweiterung.\n\nStarte deinen Mac neu und versuche anschließend erneut, das Volume einzubinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Register the %1$(productName)@ file system extension.\n\nRestart your Mac, then try mounting the volume again."
          }
        }
      }
    },
