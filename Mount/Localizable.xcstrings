    "unexpectedError.header" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unerwarteter Fehler"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unexpected Error"
          }
        }
      }
    },
    "unexpectedError.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Einbinden des %1$(productName)@ Volumes ist ein unerwarteter Fehler aufgetreten.\n\nStelle sicher, dass du die neueste Version von %1$(productName)@ verwendest.\n\nFalls das Problem weiterhin auftritt, findest du weitere Informationen im Troubleshooting Guide."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An unexpected error occurred while mounting the %1$(productName)@ volume.\n\nPlease make sure you are using the latest version of %1$(productName)@.\n\nIn case the issue persists, refer to the Troubleshooting Guide."
          }
        }
      }
    },
    "unexpectedError.troubleshooting" : {
      "extractionState" : "manual",
